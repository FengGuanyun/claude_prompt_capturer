# User session container — isolated workspace
# Each user gets their own container with restricted access

FROM python:3.13-slim

# Install useful tools for development
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    curl \
    git \
    jq \
    less \
    nano \
    nodejs \
    npm \
    procps \
    python3-pip \
    tree \
    vim-tiny \
    wget \
    zip \
    && rm -rf /var/lib/apt/lists/*

# Create workspace mount point
RUN mkdir -p /workspace

# Restrictive settings
# - No root escalation (we run as non-root)
# - Read-only filesystem (only /workspace is writable)
RUN useradd -m -s /bin/bash session_user

WORKDIR /workspace

# Default command: keep running (orchestrator execs into it)
CMD ["tail", "-f", "/dev/null"]
